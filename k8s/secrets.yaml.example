# MongoDB Secret
apiVersion: v1
kind: Secret
metadata:
  name: mongodb-secret
type: Opaque
stringData:
  username: admin
  password: change-this-password
---
# Auth Service Secret
apiVersion: v1
kind: Secret
metadata:
  name: auth-secret
type: Opaque
stringData:
  mongodb-uri: mongodb://admin:change-this-password@mongo:27017/devfactory?authSource=admin
  jwt-secret: your-super-secret-jwt-key-change-this-in-production
